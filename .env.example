# Database Configuration
DB_HOST=localhost
DB_USERNAME=root
DB_PASSWORD=your_password_here
DB_NAME=silver_entertainment
DB_PORT=3306

# Application Configuration
APP_NAME="Silver Entertainment"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/silver

# Session Configuration
SESSION_LIFETIME=120
SESSION_SECURE=false

# Admin Configuration
MAX_ADMINS=2

# File Upload Configuration
MAX_FEEDBACK_IMAGES=3
MAX_FILE_SIZE=52428800
ALLOWED_UPLOAD_EXTENSIONS=jpg,jpeg,png,gif,mp4,avi,mov,wmv,pdf,docx,txt

# Notification Configuration
NOTIFICATION_ENABLED=true
NOTIFICATION_CATEGORIES=follow,like,share,meeting,announcement,message

# AI Configuration (for trending content detection)
AI_API_KEY=your_ai_api_key_here
AI_MODEL=gpt-3.5-turbo

# Email Configuration (for notifications)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=your_email_username
MAIL_PASSWORD=your_email_password
MAIL_FROM=noreply@silverentertainment.com
